    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Outfit:wght@200;300;400;600;700&display=swap');
        
        :root {
            --bg-deep-blue: #000B1D;
            --accent-blue: #0055FF;
            --bright-blue: #00D1FF;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f8faff;
            color: #1a1a1a;
            overflow-x: hidden;
            scroll-behavior: smooth;
        }

        /* Hero */
        .hero-section {
            background: linear-gradient(135deg, #000B1D 0%, #001A4D 50%, #082f49 100%);
            min-height: 85vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
        }

        .logo-container {
            max-width: 750px;
            width: 90%;
            margin: 0 auto 1.5rem;
            z-index: 10;
        }

        /* Cards */
        .module-card-dark {
            background: linear-gradient(145deg, #001A4D, #000B1D);
            border: 1px solid rgba(0, 209, 255, 0.2);
            transition: all 0.5s ease;
        }

        .module-card-light {
            background: white;
            border: 1px solid #e2e8f0;
            transition: all 0.5s ease;
        }

        /* Timeline Flow */
        .flow-step {
            border-left: 2px solid #cbd5e1;
            padding-left: 2rem;
            position: relative;
            padding-bottom: 2rem;
        }

        .flow-step::before {
            content: '';
            position: absolute;
            left: -6px;
            top: 0;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--bright-blue);
        }

        .glass-input {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

        .glass-input:focus {
            background: rgba(255, 255, 255, 0.07);
            border-color: var(--bright-blue);
            outline: none;
        }

        #backToTop {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 45px;
            height: 45px;
            background: var(--accent-blue);
            color: white;
            border-radius: 50%;
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 100;
            box-shadow: 0 10px 20px rgba(0, 85, 255, 0.3);
        }

        #whatsappButton {
            position: fixed;
            bottom: 90px;
            right: 30px;
            width: 45px;
            height: 45px;
            background: #25D366;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 100;
            box-shadow: 0 10px 20px rgba(37, 211, 102, 0.3);
            transition: transform 0.3s ease;
        }

        .drop-cap::first-letter {
            font-size: 3.5rem;
            font-weight: 700;
            color: var(--accent-blue);
            float: left;
            margin-right: 0.75rem;
            line-height: 1;
        }
    </style>
</head>
